{
    "name": "knh/bdms",
    "description": "KNH Blood Donation Management System",
    "type": "project",
    "require": {
        "php": "^8.1",
        "africastalking/africastalking": "^3.0",
        "phpmailer/phpmailer": "^6.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "giorgiosironi/eris": "^0.13"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
